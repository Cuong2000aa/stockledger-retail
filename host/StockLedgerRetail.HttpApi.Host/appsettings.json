{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=stockledger_retail;Username=postgres;Password=201020;Maximum Pool Size=50;Timeout=30"
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379",
    "InstanceName": "stockledger:"
  },
  "Cache": {
    "Enabled": true,
    "LogOperations": false,
    "AuthTtlMinutes": 10,
    "MasterDataTtlMinutes": 30,
    "ReportTtlMinutes": 15,
    "ReportCurrentPeriodTtlMinutes": 2
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:5270"
    ]
  },
  "Integration": {
    "Sales": {
      "DefaultSourceSystem": "POS",
      "AllowedSourceSystems": [ "POS", "OMS", "ECOM", "ERP", "SHOPEE", "LAZADA", "TIKTOKSHOP" ],
      "ApiKey": "",
      "ReservationExpiryMinutes": 30,
      "FulfillmentWarehouseTypes": [ "Store", "Dc" ],
      "PreferStoreOverDc": true
    }
  },
  "Inventory": {
    "Reconciliation": {
      "Enabled": true,
      "IntervalMinutes": 60
    },
    "Insights": {
      "Enabled": true,
      "UseSnapshotOnRead": true,
      "RefreshIntervalMinutes": 30,
      "MaxSnapshotAgeMinutes": 45
    }
  },
  "Auth": {
    "RequireUserEmail": true,
    "BootstrapAdminEmail": "admin@stockledger.local",
    "StubLogin": {
      "Enabled": true,
      "Username": "admin",
      "Password": "1234",
      "UserEmail": "admin@stockledger.local"
    }
  },
  "ApprovalWorkflow": {
    "DocumentValueThreshold": 10000000
  },
  "Seed": {
    "Fb": {
      "Enabled": true
    }
  }
}
